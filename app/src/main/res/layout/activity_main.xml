<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logotipo centralizado no topo -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="@string/app_name"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/logo" />

        <!-- Card de Entrada de Dados -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Valores de Referência"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Campo de Preço da Gasolina -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_preco_gasolina"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editPrecoGasolina"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/edit_text_border"
                    android:hint="@string/hint_gasolina"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="16dp"
                    android:text="6.20"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    tools:ignore="SpeakableTextPresentCheck" />

                <!-- Campo de Preço do Álcool -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_preco_alcool"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editPrecoAlcool"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/edit_text_border"
                    android:hint="@string/hint_alcool"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="16dp"
                    android:text="4.00"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    tools:ignore="SpeakableTextPresentCheck" />

                <!-- Linha divisória sutil -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border"
                    android:layout_marginBottom="16dp"/>

                <!-- Campo de Valor a ser Abastecido -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_valor_abastecer"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editValorAbastecer"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/edit_text_border"
                    android:hint="@string/hint_valor"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    tools:ignore="SpeakableTextPresentCheck" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botão de Ação -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalcular"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_calcular"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/primary"
            app:cornerRadius="12dp"
            android:layout_marginBottom="24dp"
            app:rippleColor="#40FFFFFF"/>

        <!-- Card de Resultado (Invisível no início) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/txtTituloResultado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/resultado_titulo"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:layout_marginBottom="8dp"/>

                <!-- Recomendação em Destaque -->
                <TextView
                    android:id="@+id/txtRecomendacao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Abasteça com ÁLCOOL!"
                    android:textColor="@color/success"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- Detalhes do Rendimento -->
                <TextView
                    android:id="@+id/txtDetalhes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Com R$ 50,00 você poderá abastecer:\n• 12.50 litros de Álcool\n• 8.06 litros de Gasolina\n\nRelação de Preço: 64.52% (vantajoso abastecer com Álcool por ser menor que 70%)."
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
